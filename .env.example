# VocalTwist Configuration
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env

# ── STT Configuration ──────────────────────────────────────────────────────────
VOCALTWIST_STT_PROVIDER=whisper
VOCALTWIST_WHISPER_MODEL=base          # tiny | base | small | medium | large
VOCALTWIST_WHISPER_DEVICE=cpu          # cpu | cuda
VOCALTWIST_WHISPER_COMPUTE_TYPE=int8   # int8 | float16 | float32
VOCALTWIST_WHISPER_VAD_FILTER=true

# ── TTS Configuration ──────────────────────────────────────────────────────────
VOCALTWIST_TTS_PROVIDER=edge_tts
VOCALTWIST_DEFAULT_VOICE=en-US-AriaNeural
VOCALTWIST_DEFAULT_LANGUAGE=en

# ── Security ───────────────────────────────────────────────────────────────────
# Set to true and provide API keys to restrict access.
# NEVER commit real keys — use a secrets manager in production.
VOCALTWIST_API_KEY_ENABLED=false
VOCALTWIST_API_KEYS=                   # comma-separated: key1,key2,key3
VOCALTWIST_RATE_LIMIT_ENABLED=true
VOCALTWIST_RATE_LIMIT_TRANSCRIBE=20/minute
VOCALTWIST_RATE_LIMIT_SPEAK=30/minute

# ── Audio Limits ───────────────────────────────────────────────────────────────
VOCALTWIST_MAX_AUDIO_BYTES=10485760    # 10 MB

# ── CORS ───────────────────────────────────────────────────────────────────────
# Use * only for development. In production specify exact origins:
#   VOCALTWIST_CORS_ORIGINS=https://app.example.com,https://admin.example.com
VOCALTWIST_CORS_ORIGINS=*

# ── Translation ────────────────────────────────────────────────────────────────
# WARNING: enabling this sends transcribed text to Google Cloud Translation.
# Review your data-handling obligations (GDPR, CCPA) before enabling.
VOCALTWIST_ALLOW_CLOUD_TRANSLATION=false

# ── Observability ─────────────────────────────────────────────────────────────
VOCALTWIST_LOG_LEVEL=INFO
VOCALTWIST_LOG_FORMAT=json             # json | text

# ── VocalTwistTest Demo — LM Studio ───────────────────────────────────────────
# Point LM_STUDIO_URL at your running LM Studio instance.
# When running inside Docker, host.docker.internal resolves to the host machine.
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_MODEL=mistralai/ministral-3-3b
